    "HUMAN_REVIEW": {
      "conditions": ["conflictingSignals == true OR criticalDisclosureDetected == true"],
      "blockers": [],
      "riskConditions": ["audit_opinion_risk >= 70 OR macro_event_risk_score >= 75"],
      "confidenceRequirement": "manual_review_required",
      "userMessage": "자동 판단보다 전문가 검토가 필요한 예외 상황입니다.",
