{
  "domain": "overlap-penalty",
  "schemaVersion": "stockai.rules.scoring.v2",
  "description": "Overlap penalty, signal conflict resolution, and independent signal verification.",
  "penalties": {
    "FeatureOverlapPenalty": {
      "formula": "0.10*Correlation(VolumeScore,BreakoutScore)+0.10*Correlation(VWAPScore,TrendScore)+0.10*Correlation(FlowScore,ProgramScore)+0.10*Correlation(SmartMoneyScore,VolumeScore)",
      "capWhenCorrelationGte": 0.8,
      "overlappingBonusCap": 0.5
    },
    "FeatureCorrelationPenalty": {
      "correlationThreshold": 0.82,
      "maxPenalty": 0.18
    },
    "SourceContributionCap": {
      "caps": {
        "price": 0.28,
        "volume": 0.22,
        "news": 0.18,
        "flow": 0.22,
        "sentiment": 0.16
      }
    },
    "GroupContributionCap": {
      "caps": {
        "BreakoutScore": 0.22,
        "RiskScore": 0.3,
        "SentimentScore": 0.16
      }
    },
    "IndependentSignalCount": {
      "groups": [
        "price_structure",
        "volume",
        "vwap_execution",
        "foreign_institution_flow",
        "news_disclosure",
        "financial",
        "sector_regime",
        "orderbook_liquidity",
        "derivative_short",
        "sentiment_narrative"
      ],
      "minimumForBuyNow": 5,
      "minimumForWatchlist": 2,
      "penaltyIfBelow3": "ConfidenceScore -5"
    },
    "RiskSignalOverride": {
      "overrideWhen": [
        "Critical Gate == true",
        "delisting_risk >= 80",
        "data_quality_risk >= 75",
        "liquidity_risk_score >= 85"
      ]
    }
  },
  "signalConflictResolution": {
    "priority": [
      "Critical Gate",
      "High Risk Gate",
      "Medium Risk Gate",
      "marketability",
      "VWAP status",
      "close position",
      "volume persistence",
      "absorption and cumulative delta",
      "flow direction",
      "market regime",
      "stock type",
      "final score"
    ],
    "examples": [
      "new_high_breakout vs upper_wick_and_vwap_loss",
      "positive_news vs bearish_candle",
      "gap_up vs gap_fill_failure",
      "strong_close vs closing_auction_sell_imbalance",
      "spot_flow_positive vs derivative_overheat"
    ]
  }
}
